# Supabase: public browser config for Google login and per-user lesson history.
# The app also has these values as a checked-in fallback in src/supabaseClient.ts,
# so GitHub/Pages builds work even if VITE_SUPABASE_* is not configured.
VITE_SUPABASE_URL="https://dlehdgvheztziiwurdtl.supabase.co"
VITE_SUPABASE_ANON_KEY="sb_publishable_Sl3ZH6H1K58tX2Ei_BRwVQ_MoKw_y8r"

# Supabase Dashboard must allow the exact public app URL under:
# Authentication > URL Configuration > Site URL / Redirect URLs.
# Example for GitHub Pages: https://username.github.io/repository-name/

# Optional server fallback. Leave empty if every user saves their own Gemini key
# inside the app after Google login.
GEMINI_API_KEY=""

# Optional: fallback chain used when a Gemini model returns 503/UNAVAILABLE.
GEMINI_MODEL_CHAIN="gemini-3.5-flash,gemini-2.5-flash,gemini-2.5-flash-lite"
